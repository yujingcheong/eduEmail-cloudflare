# Supabase Edge Functions Environment Configuration
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudflare Configuration (keep existing values)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_DOMAIN=your-domain.com
CLOUDFLARE_WORKER_NAME=your-worker-name
CLOUDFLARE_WORKER_ROUTE=your-domain.com

# Example values (replace with your actual configuration):
# SUPABASE_URL=https://abcdefghijk.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# CLOUDFLARE_API_TOKEN=abcd1234567890
# CLOUDFLARE_ZONE_ID=abcd1234567890
# CLOUDFLARE_DOMAIN=example.edu.kg
# CLOUDFLARE_WORKER_NAME=email-parser
# CLOUDFLARE_WORKER_ROUTE=example.edu.kg